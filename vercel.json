{
  "buildCommand": "npm run build",
  "installCommand": "npm install --workspaces --include-workspace-root --legacy-peer-deps",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
